{
  "name": "code-copy",
  "displayName": "Code Copy",
  "publisher": "genius-programmer",
  "description": "Copy workspace file paths to clipboard with extension filters",
  "version": "0.0.1",
  "license": "MIT",
  "icon": "media/logo.png",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeCopy",
          "title": "Code Copy",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codeCopy": [
        {
          "type": "webview",
          "id": "codeCopy.view",
          "name": "Export"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0"
  }
}
